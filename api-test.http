### ============================================
### 变量
### ============================================
@baseUrl = http://localhost:8080
@aiUrl = http://localhost:5001
@nginxUrl = http://39.106.209.208:9092
@internalToken = smart-class-ai-internal-token-2026
@jwt = {{login.response.body.data.token}}

### ============================================
### 0. 系统健康检查
### ============================================

### 健康检查（无需鉴权）
GET {{baseUrl}}/system/health

### ============================================
### 1. 认证（AuthController）
### ============================================

### 登录
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{"username":"admin","password":"admin123"}

### 注册
POST {{baseUrl}}/auth/register
Content-Type: application/json

{"username":"newuser","password":"123456","nickname":"新用户"}

### 注册-用户名重复
POST {{baseUrl}}/auth/register
Content-Type: application/json

{"username":"admin","password":"123456"}

### 注册-参数校验（用户名过短）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{"username":"a","password":"123456"}

### 注册-参数校验（密码过短）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{"username":"testuser","password":"123"}

### 获取当前用户信息
GET {{baseUrl}}/auth/info
Authorization: Bearer {{jwt}}

### 退出登录
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{jwt}}

### ============================================
### 2. 用户管理（UserController, admin 专用）
### ============================================

### 用户列表
GET {{baseUrl}}/users?page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 用户列表-按角色筛选
GET {{baseUrl}}/users?role=teacher&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 用户列表-按状态筛选
GET {{baseUrl}}/users?status=enabled&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 用户详情（需替换真实 id）
GET {{baseUrl}}/users/1
Authorization: Bearer {{jwt}}

### 编辑用户（昵称/头像）
PUT {{baseUrl}}/users/2
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"nickname":"张老师","avatarUrl":""}

### 变更用户角色（admin→teacher 或 teacher→admin）
PUT {{baseUrl}}/users/2/role
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"role":"teacher"}

### 禁用用户
PUT {{baseUrl}}/users/2/status
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"status":"disabled"}

### 启用用户
PUT {{baseUrl}}/users/2/status
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"status":"enabled"}

### 删除用户（软删除，不能删除自己）
DELETE {{baseUrl}}/users/2
Authorization: Bearer {{jwt}}

### ============================================
### 3. RBAC 权限验证
### ============================================

### teacher 登录（用于权限对比测试）
# @name teacherLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{"username":"teacher","password":"teacher123"}

### teacher 读视频源（应 200）
GET {{baseUrl}}/streams?page=1&pageSize=10
Authorization: Bearer {{teacherLogin.response.body.data.token}}

### teacher 新增视频源（应 403）
POST {{baseUrl}}/streams
Authorization: Bearer {{teacherLogin.response.body.data.token}}
Content-Type: application/json

{"streamName":"test","streamId":"test_01","rtmpUrl":"rtmp://localhost:9090/live/test_01","remark":""}

### teacher 新增人员（应 403）
POST {{baseUrl}}/students
Authorization: Bearer {{teacherLogin.response.body.data.token}}
Content-Type: application/json

{"studentNo":"9999","name":"test","className":"test"}

### teacher 查操作日志（应 403）
GET {{baseUrl}}/operation-logs?page=1&pageSize=10
Authorization: Bearer {{teacherLogin.response.body.data.token}}

### teacher 访问用户管理（应 403）
GET {{baseUrl}}/users?page=1&pageSize=10
Authorization: Bearer {{teacherLogin.response.body.data.token}}

### admin 新增视频源（应 200）
POST {{baseUrl}}/streams
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"streamName":"test","streamId":"test_01","rtmpUrl":"rtmp://localhost:9090/live/test_01","remark":""}

### admin 访问用户管理（应 200）
GET {{baseUrl}}/users?page=1&pageSize=10
Authorization: Bearer {{jwt}}

### ============================================
### 4. 视频源（StreamController）
### ============================================

### 视频源列表（分页）
GET {{baseUrl}}/streams?page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 视频源列表-按状态筛选
GET {{baseUrl}}/streams?status=enabled&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 视频源列表-按关键词搜索
GET {{baseUrl}}/streams?keyword=教室&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 已启用视频源（不分页）
GET {{baseUrl}}/streams/enabled
Authorization: Bearer {{jwt}}

### 视频源详情（需替换真实数据库主键 id）
GET {{baseUrl}}/streams/1
Authorization: Bearer {{jwt}}

### 新增视频源（admin）
POST {{baseUrl}}/streams
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"streamName":"3号教室","streamId":"classroom_03","rtmpUrl":"rtmp://localhost:9090/live/classroom_03","remark":""}

### 编辑视频源（admin, 需替换真实数据库主键 id）
PUT {{baseUrl}}/streams/1
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"streamName":"3号教室-更新","rtmpUrl":"rtmp://localhost:9090/live/classroom_03","status":"enabled","remark":"更新备注"}

### 删除视频源（admin, 需替换真实数据库主键 id）
DELETE {{baseUrl}}/streams/1
Authorization: Bearer {{jwt}}

### 推流状态（路径参数为 stream_id 业务标识）
GET {{baseUrl}}/streams/classroom_01/status
Authorization: Bearer {{jwt}}

### 播放地址（路径参数为 stream_id 业务标识）
GET {{baseUrl}}/streams/classroom_01/preview-url
Authorization: Bearer {{jwt}}

### ============================================
### 5. 告警事件（AlertController）
### ============================================

### 告警列表（分页）
GET {{baseUrl}}/alerts?page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 告警列表-按视频源筛选
GET {{baseUrl}}/alerts?streamId=classroom_01&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 告警列表-按类型筛选
GET {{baseUrl}}/alerts?alertType=head_down&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 告警列表-按状态筛选
GET {{baseUrl}}/alerts?status=unhandled&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 告警列表-按等级筛选
GET {{baseUrl}}/alerts?level=high&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 告警列表-按时间范围筛选
GET {{baseUrl}}/alerts?startTime=2026-07-01T00:00:00&endTime=2026-07-12T23:59:59&page=1&pageSize=10
Authorization: Bearer {{jwt}}

### 告警详情（需替换真实数据库主键 id）
GET {{baseUrl}}/alerts/1
Authorization: Bearer {{jwt}}

### 更新告警状态（需替换真实数据库主键 id）
PUT {{baseUrl}}/alerts/1/status
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"status":"processing","handlerId":1,"remark":"正在处理"}

### 告警统计
GET {{baseUrl}}/alert-stats
Authorization: Bearer {{jwt}}

### ============================================
### 6. 区域配置（ZoneController）
### ============================================

### 区域列表
GET {{baseUrl}}/zones
Authorization: Bearer {{jwt}}

### 区域列表-按视频源筛选
GET {{baseUrl}}/zones?streamId=classroom_01
Authorization: Bearer {{jwt}}

### 区域列表-按类型筛选
GET {{baseUrl}}/zones?zoneType=danger
Authorization: Bearer {{jwt}}

### 区域详情（需替换真实数据库主键 id）
GET {{baseUrl}}/zones/1
Authorization: Bearer {{jwt}}

### 新增区域
POST {{baseUrl}}/zones
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"streamId":"classroom_01","zoneName":"讲台危险区","zoneType":"danger","coordinates":"[{\"x\":0.1,\"y\":0.1},{\"x\":0.5,\"y\":0.1},{\"x\":0.5,\"y\":0.5},{\"x\":0.1,\"y\":0.5}]","thresholdSeconds":2,"safeDistance":0.05}

### 修改区域（需替换真实数据库主键 id）
PUT {{baseUrl}}/zones/1
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"zoneName":"讲台危险区-更新","coordinates":"[{\"x\":0.1,\"y\":0.1},{\"x\":0.6,\"y\":0.1},{\"x\":0.6,\"y\":0.6},{\"x\":0.1,\"y\":0.6}]","thresholdSeconds":5,"safeDistance":0.08,"enabled":true}

### 删除区域（需替换真实数据库主键 id）
DELETE {{baseUrl}}/zones/1
Authorization: Bearer {{jwt}}

### 切换区域开关（teacher 可调用）
PUT {{baseUrl}}/zones/1/toggle?enabled=false
Authorization: Bearer {{jwt}}

### 获取视频源全部区域
GET {{baseUrl}}/streams/classroom_01/zones
Authorization: Bearer {{jwt}}

### ============================================
### 7. 行为规则（RuleController）
### ============================================

### 规则列表
GET {{baseUrl}}/rules
Authorization: Bearer {{jwt}}

### 规则列表-按类型筛选
GET {{baseUrl}}/rules?ruleType=phone_usage
Authorization: Bearer {{jwt}}

### 规则详情（需替换真实数据库主键 id）
GET {{baseUrl}}/rules/1
Authorization: Bearer {{jwt}}

### 新增规则（admin）
POST {{baseUrl}}/rules
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"ruleType":"danger_zone","ruleName":"危险区域检测","enabled":true,"thresholdSeconds":2,"confidenceThreshold":0.6,"cooldownSeconds":45,"level":"warning","configJson":"{\"safe_distance\":0.05}"}

### 更新规则（admin, 需替换真实数据库主键 id）
PUT {{baseUrl}}/rules/1
Authorization: Bearer {{jwt}}
Content-Type: application/json

{"ruleName":"危险区域检测-更新","thresholdSeconds":5,"confidenceThreshold":0.8,"cooldownSeconds":60,"level":"high","enabled":true,"configJson":"{\"safe_distance\":0.05}"}

### 删除规则（admin, 需替换真实数据库主键 id）
DELETE {{baseUrl}}/rules/1
Authorization: Bearer {{jwt}}

### 切换规则开关（teacher 可调用）
PUT {{baseUrl}}/rules/1/toggle?enabled=false
Authorization: Bearer {{jwt}}

