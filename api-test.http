Authorization: Bearer {{jwt}}

### ============================================
### 13. 日报（ReportController, 无需鉴权）
### ============================================

### 获取最新日报
GET {{baseUrl}}/report/latest

### 手动生成日报（admin, 传入告警列表）
POST {{baseUrl}}/report/generate
Authorization: Bearer {{jwt}}
Content-Type: application/json

[
  {"alertType":"head_down","level":"warning","streamId":"classroom_01","snapshotUrl":""},
  {"alertType":"stranger_detected","level":"high","streamId":"classroom_01","snapshotUrl":""}
]

### 日报历史
GET {{baseUrl}}/report/history

### ============================================
### 14. 系统设置（SettingsController, 无需鉴权）
### ============================================

### 获取系统设置
GET {{baseUrl}}/api/settings

### 更新系统设置
PUT {{baseUrl}}/api/settings
Content-Type: application/json

{
  "contacts": [
    {"name":"项重善","mobile":"18601033435"},
    {"name":"章志超","mobile":"15270985055"}
  ],
  "responsible": "项重善",
  "reportTime": "18:00"
}

### ============================================
### 15. AI 内部接口 → Spring Boot（带 X-Internal-Token）
### ============================================

### 视频流列表
GET {{baseUrl}}/streams
X-Internal-Token: {{internalToken}}

### 区域列表
GET {{baseUrl}}/zones?streamId=classroom_01
X-Internal-Token: {{internalToken}}

### 规则列表
GET {{baseUrl}}/rules
X-Internal-Token: {{internalToken}}

### 获取全量人脸特征（含特征向量，禁止前端访问）
GET {{baseUrl}}/students/face-features
X-Internal-Token: {{internalToken}}

### AI 告警入库（event_id 幂等）
POST {{baseUrl}}/alerts/ai
X-Internal-Token: {{internalToken}}
Content-Type: application/json

{
  "eventId": "evt_20260710143000001",
  "streamId": "classroom_01",
  "alertType": "danger_zone_intrusion",
  "alertName": "危险区域入侵",
  "level": "warning",
  "confidence": 0.85,
  "occurredAt": "2026-07-10T14:30:00+08:00",
  "durationSeconds": 3.5,
  "studentId": null,
  "targetInfo": {"track_id":1,"bbox":[100,200,150,300]},
  "zoneId": 1,
  "snapshotPath": "/snapshots/evt_xxx.jpg",
  "recordPath": null,
  "eventTimeOffset": null,
  "extra": {"source":"backend_ai"}
}

### AI 告警入库-明火检测
POST {{baseUrl}}/alerts/ai
X-Internal-Token: {{internalToken}}
Content-Type: application/json

{
  "eventId": "evt_20260710143000002",
  "streamId": "classroom_01",
  "alertType": "fire_detected",
  "alertName": "明火检测",
  "level": "high",
  "confidence": 0.92,
  "occurredAt": "2026-07-10T14:35:00+08:00",
  "durationSeconds": 1.5,
  "studentId": null,
  "targetInfo": {"track_id":2,"bbox":[200,100,300,250]},
  "zoneId": null,
  "snapshotPath": "/snapshots/evt_fire_001.jpg",
  "recordPath": null,
  "eventTimeOffset": null,
  "extra": {"source":"backend_ai","model":"yolov8"}
}

### AI 告警入库-重复 event_id 幂等测试
POST {{baseUrl}}/alerts/ai
X-Internal-Token: {{internalToken}}
Content-Type: application/json

{
  "eventId": "evt_20260710143000001",
  "streamId": "classroom_01",
  "alertType": "danger_zone_intrusion",
  "alertName": "危险区域入侵",
  "level": "warning",
  "confidence": 0.85,
  "occurredAt": "2026-07-10T14:30:00+08:00"
}

### ============================================
### 16. AI 服务接口（Flask）
### ============================================

### 分析摘要
GET {{aiUrl}}/analysis/summary/classroom_01

### 触发 AI 重载配置
POST {{aiUrl}}/config/reload

### 重载人脸特征
POST {{aiUrl}}/face/features/reload

### AI 模型状态（含 snapshot_pusher 是否启用）
GET {{aiUrl}}/model/status

### ============================================
### 17. 截图 & 证据（Nginx 静态资源）
### ============================================

### 云服务器 Nginx 截图（生产环境，前端实际访问路径）
GET {{nginxUrl}}/snapshots/20260712/evt_b10caf1f1fe840f3.jpg