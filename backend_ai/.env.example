# Spring Boot 后端地址
SPRING_BASE_URL=http://localhost:8080

# AI 内部接口鉴权 Token（需与 backend_system 的 ai.internal-token 一致）
INTERNAL_TOKEN=example-token

# 截图远程推送配置（留空则不推送）
SNAPSHOT_REMOTE_HOST=
SNAPSHOT_REMOTE_USER=root
SNAPSHOT_REMOTE_PATH=/data/snapshots

# 录像切片配置
RECORDING_SEGMENT_SECONDS=30
RECORDING_SEGMENT_DIR=/records

# 钉钉企业机器人配置（留空则禁用钉钉通知）
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_WEBHOOK=
DINGTALK_GROUP_ID=