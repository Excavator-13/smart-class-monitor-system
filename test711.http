@aiBase = http://localhost:5001
@apiBase = http://localhost:8080
@streamId = classroom_01
@studentId = 1
@token = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxIiwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGUiOiJhZG1pbiIsImlhdCI6MTc4MzkwNzc4OCwiZXhwIjoxNzgzOTk0MTg4fQ.FIcVCNTWOKVKAqDhVEFaNPQwmRwe61U3KFNu_g4d_IU
@internalToken = smart-class-ai-internal-token-2026

### 1. AI模型状态
GET {{aiBase}}/model/status

### 2. SpringBoot视频源配置
GET {{apiBase}}/streams
Authorization: Bearer {{token}}

### 3. 视频源推流状态
GET {{apiBase}}/streams/{{streamId}}/status
Authorization: Bearer {{token}}

### 4. 刷新AI配置
POST {{aiBase}}/config/reload
Content-Type: application/json

{
  "stream_id": "{{streamId}}",
  "reload_items": ["streams", "zones", "rules"]
}

### 5. 创建人员（只需执行一次）
POST {{apiBase}}/students
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "student_no": "TEST_001",
  "name": "联调测试人员",
  "class_name": "联调测试班",
  "status": "enabled",
  "remark": "7月11日人脸联调"
}

### 6. 通过SpringBoot注册人脸
POST {{apiBase}}/students/{{studentId}}/face
Authorization: Bearer {{token}}
Content-Type: application/json  

{
  "image": ""
}

### 7. 查询人员详情
GET {{apiBase}}/students/{{studentId}}
Authorization: Bearer {{token}}

### 8. 内部查询人脸特征
GET {{apiBase}}/students/face-features
X-Internal-Token: {{internalToken}}

### 9. 手动刷新AI人脸特征缓存
POST {{aiBase}}/face/features/reload
Content-Type: application/json

{
  "scope": "all"
}

### 10. AI拉流及人脸画框
GET {{aiBase}}/video_feed/{{streamId}}?annotate=true&modules=face

### 11. 查询人脸识别事件
GET {{aiBase}}/analysis/events?stream_id={{streamId}}&event_type=face_recognized&limit=20

### 12. 查询陌生人事件
GET {{aiBase}}/analysis/events?stream_id={{streamId}}&event_type=stranger_detected&limit=20

### 13. 查询分析摘要
GET {{aiBase}}/analysis/summary/{{streamId}}

### 14. 查询正式告警
GET {{apiBase}}/alerts?stream_id={{streamId}}
Authorization: Bearer {{token}}

### 15. 系统整体健康状态
GET {{apiBase}}/system/health